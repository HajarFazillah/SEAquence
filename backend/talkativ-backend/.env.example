# MySQL Database (see /infra)
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_DATABASE=talkativ
MYSQL_USER=root
MYSQL_PASSWORD=changeme

# JWT
jwt.secret=replace_with_a_long_random_secret
jwt.expiration=86400000

# AI Analysis Server
ai.server.url=http://localhost:8000

# CLOVA Speech Recognition
clova.speech.url=your_clova_speech_endpoint
clova.speech.secret=your_clova_speech_secret

# Email (SMTP) — required only for password-reset emails
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_app_password
